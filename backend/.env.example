# UniBlack backend env template
# Copy to backend/.env and fill in. DO NOT commit the real .env.

# Server
PORT=8080
ECHO_MODE=debug

# PostgreSQL
DATABASE_URL=postgres://uniblack:uniblack@localhost:5432/uniblack?sslmode=disable

# JWT / Refresh tokens
JWT_SECRET=change-me-access-secret
REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# MinIO (S3-compatible) for evidence storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uniblack-evidence
MINIO_USE_SSL=false

# Migrations
MIGRATIONS_PATH=./internal/migrations

# --- System options (NewAPI-style; DB overrides these after first run) ---
# Site
SITE_NAME=UniBlack
SITE_DESCRIPTION=一个可复用的通用云黑系统
SITE_THEME_COLOR=#3B82F6
SITE_LOGO_URL=
SITE_CONTACT_EMAIL=

# Registration / security
REGISTER_ENABLED=true
EMAIL_VERIFICATION_ENABLED=false
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# SMTP (used when EMAIL_VERIFICATION_ENABLED=true)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SSL_ENABLED=false
SMTP_INSECURE_SKIP_VERIFY=false

# Rate limits
RATE_LIMIT_PUBLIC=20
RATE_LIMIT_AUTH=10

# OAuth (optional)
OAUTH_GITHUB_ENABLED=false
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
